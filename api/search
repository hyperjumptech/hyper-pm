norepo-15","page_id":"/development/monorepo","type":"text","url":"/development/monorepo#common-scripts-root","content":"Purpose"},"627":{"id":"/development/monorepo-16","page_id":"/development/monorepo","type":"text","url":"/development/monorepo#common-scripts-root","content":"pnpm install"},"628":{"id":"/development/monorepo-17","page_id":"/development/monorepo","type":"text","url":"/development/monorepo#common-scripts-root","content":"Install workspace dependencies"},"629":{"id":"/development/monorepo-18","page_id":"/development/monorepo","type":"text","url":"/development/monorepo#common-scripts-root","content":"pnpm build"},"630":{"id":"/development/monorepo-19","page_id":"/development/monorepo","type":"text","url":"/development/monorepo#common-scripts-root","content":"turbo build across packages"},"631":{"id":"/development/monorepo-20","page_id":"/development/monorepo","type":"text","url":"/development/monorepo#common-scripts-root","content":"pnpm code-quality"},"632":{"id":"/development/monorepo-21","page_id":"/development/monorepo","type":"text","url":"/development/monorepo#common-scripts-root","content":"Lint, tests, and type-check (gate for contributions)"},"633":{"id":"/development/monorepo-22","page_id":"/development/monorepo","type":"text","url":"/development/monorepo#common-scripts-root","content":"pnpm docs:dev"},"634":{"id":"/development/monorepo-23","page_id":"/development/monorepo","type":"text","url":"/development/monorepo#common-scripts-root","content":"Speed Docs dev server for /docs content"},"635":{"id":"/development/monorepo-24","page_id":"/development/monorepo","type":"text","url":"/development/monorepo#common-scripts-root","content":"pnpm docs:build"},"636":{"id":"/development/monorepo-25","page_id":"/development/monorepo","type":"text","url":"/development/monorepo#common-scripts-root","content":"Static build of the documentation site"},"637":{"id":"/development/monorepo-26","page_id":"/development/monorepo","type":"text","url":"/development/monorepo#database-and-other-services","content":"Some workspace packages or tests may expect Postgres or other services via docker-compose. Follow the root README.md for local infra commands relevant to your task."},"638":{"id":"/integrations/github-sync","page_id":"/integrations/github-sync","type":"page","content":"GitHub sync","url":"/integrations/github-sync"},"639":{"id":"/integrations/github-sync-0","page_id":"/integrations/github-sync","type":"text","url":"/integrations/github-sync","content":"Outbound and full inbound sync, labels, planning JSON, and PR activity."},"640":{"id":"/integrations/github-sync-1","page_id":"/integrations/github-sync","type":"heading","url":"/integrations/github-sync#two-ways-to-run-sync","content":"Two ways to run sync"},"641":{"id":"/integrations/github-sync-2","page_id":"/integrations/github-sync","type":"heading","url":"/integrations/github-sync#config-sync-field","content":"Config sync field"},"642":{"id":"/integrations/github-sync-3","page_id":"/integrations/github-sync","type":"heading","url":"/integrations/github-sync#outbound-behavior","content":"Outbound behavior"},"643":{"id":"/integrations/github-sync-4","page_id":"/integrations/github-sync","type":"heading","url":"/integrations/github-sync#inbound-part-of---with-github","content":"Inbound (part of --with-github)"},"644":{"id":"/integrations/github-sync-5","page_id":"/integrations/github-sync","type":"heading","url":"/integrations/github-sync#issue-creation-vs-update","content":"Issue creation vs update"},"645":{"id":"/integrations/github-sync-6","page_id":"/integrations/github-sync","type":"heading","url":"/integrations/github-sync#assignees","content":"Assignees"},"646":{"id":"/integrations/github-sync-7","page_id":"/integrations/github-sync","type":"text","url":"/integrations/github-sync#two-ways-to-run-sync","content":"Git data only — plain hyper-pm sync (no flags). Runs git fetch / git merge / git push for the data branch. No GitHub API, no token. Runs even when sync is off in config."},"647":{"id":"/integrations/github-sync-8","page_id":"/integrations/github-sync","type":"text","url":"/integrations/github-sync#two-ways-to-run-sync","content":"Git + full GitHub mirror — hyper-pm sync --with-github. Pushes ticket changes to GitHub Issues, pulls inbound edits into JSONL, then ingests linked PR timeline activity when applicable. Requires auth and a config where sync is not off."},"648":{"id":"/integrations/github-sync-9","page_id":"/integrations/github-sync","type":"text","url":"/integrations/github-sync#two-ways-to-run-sync","content":"The legacy --git-data flag is a no-op (plain sync is already git-only)."},"649":{"id":"/integrations/github-sync-10","page_id":"/integrations/github-sync","type":"text","url":"/integrations/github-sync#config-sync-field","content":"off — sync --with-github is rejected."},"650":{"id":"/integrations/github-sync-11","page_id":"/integrations/github-sync","type":"text","url":"/integrations/github-sync#config-sync-field","content":"outbound or full — both allow sync --with-github and behave the same: the CLI always runs outbound, inbound, and PR activity together. The two values remain for backward compatibility with existing config.json files."},"651":{"id":"/integrations/github-sync-12","page_id":"/integrations/github-sync","type":"text","url":"/integrations/github-sync#outbound-behavior","content":"Issue labels include hyper-pm, ticket, plus each ticket label (GitHub’s label length limits apply)."},"652":{"id":"/integrations/github-sync-13","page_id":"/integrations/github-sync","type":"text","url":"/integrations/github-sync#outbound-behavior","content":"Ticket planning (priority, size, estimate, schedule) is embedded in a fenced JSON block after the issue body so full inbound can round-trip fields conservatively (only keys present in the fence participate — older issues without keys are not mass-cleared)."},"653":{"id":"/integrations/github-sync-14","page_id":"/integrations/github-sync","type":"text","url":"/integrations/github-sync#inbound-part-of---with-github","content":"Compares non-reserved labels and the planning JSON fence to the local projection and appends GithubInboundUpdate when something differs. When an issue’s body references a ticket id but the projection row has no githubIssueNumber yet, inbound appends GithubIssueLinked once so PR discovery can use that issue number (covers manually linked GitHub issues and older data). If the issue has several JSON fenced blocks, hyper-pm uses the one that contains hyper_pm_id (so a JSON snippet earlier in the description does not hide the real metadata fence)."},"654":{"id":"/integrations/github-sync-15","page_id":"/integrations/github-sync","type":"text","url":"/integrations/github-sync#inbound-part-of---with-github","content":"After inbound, for tickets that are not done or cancelled, hyper-pm resolves linked PR numbers from Refs / Closes / Fixes / Resolves in the ticket body, from the GitHub issue timeline for githubIssueNumber, and (when needed) from a search of open PRs with linked:issue whose bodies reference that issue (Closes / Fixes / Resolves / Refs). It then loads PR timelines, appending GithubPrActivity events. Replaying kind: \"opened\" (only while the PR is open) sets in_progress; kind: \"merged\" sets done. Projection replay applies all other events first, then GithubPrActivity in time order, so PR timestamps from GitHub (often before the hyper-pm ticket was created) still update status correctly. This uses extra GitHub API calls (including search when any ticket has a linked GitHub issue)."},"655":{"id":"/integrations/github-sync-16","page_id":"/integrations/github-sync","type":"text","url":"/integrations/github-sync#issue-creation-vs-update","content":"Creates on GitHub only happen for tickets with a valid epic + story chain."},"656":{"id":"/integrations/github-sync-17","page_id":"/integrations/github-sync","type":"text","url":"/integrations/github-sync#issue-creation-vs-update","content":"Tickets without a story are skipped for creation until you attach --story."},"657":{"id":"/integrations/github-sync-18","page_id":"/integrations/github-sync","type":"text","url":"/integrations/github-sync#issue-creation-vs-update","content":"Tickets that already have a githubIssueNumber are still updated when unlinked (the issue body drops parent ids until you link again)."},"658":{"id":"/integrations/github-sync-19","page_id":"/integrations/github-sync","type":"text","url":"/integrations/github-sync#assignees","content":"Tickets store at most one assignee (GitHub login). Outbound sync sets that user as the issue’s assignee (additional assignees on the issue may be removed). Inbound reads the first assignee when GitHub returns several."},"659":{"id":"/integrations/github-sync-20","page_id":"/integrations/github-sync","type":"text","url":"/integrations/github-sync#assignees","content":"type: warn"},"660":{"id":"/integrations/github-sync-21","page_id":"/integrations/github-sync","type":"text","url":"/integrations/github-sync#assignees","content":"sync --skip-network (legacy: --no-github) skips all sync network work (git and GitHub). sync --with-github requires GITHUB_TOKEN or gh and needs sync not off in config."},"661":{"id":"/integrations/mcp-server","page_id":"/integrations/mcp-server","type":"page","content":"MCP server (hyper-pm-mcp)","url":"/integrations/mcp-server"},"662":{"id":"/integrations/mcp-server-0","page_id":"/integrations/mcp-server","type":"text","url":"/integrations/mcp-server","content":"Model Context Protocol stdio server — install, Cursor and Claude Desktop setup, tool shape, and security."},"663":{"id":"/integrations/mcp-server-1","page_id":"/integrations/mcp-server","type":"heading","url":"/integrations/mcp-server#security","content":"Security"},"664":{"id":"/integrations/mcp-server-2","page_id":"/integrations/mcp-server","type":"heading","url":"/integrations/mcp-server#install-and-build-order","content":"Install and build order"},"665":{"id":"/integrations/mcp-server-3","page_id":"/integrations/mcp-server","type":"heading","url":"/integrations/mcp-server#from-npm-published-packages","content":"From npm (published packages)"},"666":{"id":"/integrations/mcp-server-4","page_id":"/integrations/mcp-server","type":"heading","url":"/integrations/mcp-server#from-this-monorepo-development","content":"From this monorepo (development)"},"667":{"id":"/integrations/mcp-server-5","page_id":"/integrations/mcp-server","type":"heading","url":"/integrations/mcp-server#build-the-cli","content":"Build the CLI"},"668":{"id":"/integrations/mcp-server-6","page_id":"/integrations/mcp-server","type":"heading","url":"/integrations/mcp-server#build-the-mcp-server","content":"Build the MCP server"},"669":{"id":"/integrations/mcp-server-7","page_id":"/integrations/mcp-server","type":"heading","url":"/integrations/mcp-server#register-the-server-in-your-editor","content":"Register the server in your editor"},"670":{"id":"/integrations/mcp-server-8","page_id":"/integrations/mcp-server","type":"heading","url":"/integrations/mcp-server#environment","content":"Environment"},"671":{"id":"/integrations/mcp-server-9","page_id":"/integrations/mcp-server","type":"heading","url":"/integrations/mcp-server#tool-hyper_pm_run","content":"Tool: hyper_pm_run"},"672":{"id":"/integrations/mcp-server-10","page_id":"/integrations/mcp-server","type":"heading","url":"/integrations/mcp-server#input-json","content":"Input (JSON)"},"673":{"id":"/integrations/mcp-server-11","page_id":"/integrations/mcp-server","type":"heading","url":"/integrations/mcp-server#example-tool-inputs","content":"Example tool inputs"},"674":{"id":"/integrations/mcp-server-12","page_id":"/integrations/mcp-server","type":"heading","url":"/integrations/mcp-server#output","content":"Output"},"675":{"id":"/integrations/mcp-server-13","page_id":"/integrations/mcp-server","type":"heading","url":"/integrations/mcp-server#cursor","content":"Cursor"},"676":{"id":"/integrations/mcp-server-14","page_id":"/integrations/mcp-server","type":"heading","url":"/integrations/mcp-server#claude-desktop","content":"Claude Desktop"},"677":{"id":"/integrations/mcp-server-15","page_id":"/integrations/mcp-server","type":"heading","url":"/integrations/mcp-server#publishing-maintainers","content":"Publishing (maintainers)"},"678":{"id":"/integrations/mcp-server-16","page_id":"/integrations/mcp-server","type":"text","url":"/integrations/mcp-server","content":"hyper-pm-mcp is a stdio Model Context Protocol server. MCP-capable editors and apps (for example Cursor, Claude Desktop) can call a single tool, hyper_pm_run, which spawns the same hyper-pm CLI you would run locally."},"679":{"id":"/integrations/mcp-server-17","page_id":"/integrations/mcp-server","type":"text","url":"/integrations/mcp-server","content":"Use it when you want an AI assistant to read epics, list tickets, run doctor, or drive sync, without hand-copying JSON between chat and the terminal."},"680":{"id":"/integrations/mcp-server-18","page_id":"/integrations/mcp-server","type":"text","url":"/integrations/mcp-server#security","content":"type: warn"},"681":{"id":"/integrations/mcp-server-19","page_id":"/integrations/mcp-server","type":"text","url":"/integrations/mcp-server#security","content":"hyper_pm_run executes real hyper-pm processes with the arguments the model supplies (within the JSON schema). Only enable this server in trusted MCP configurations, and keep tokens out of shared project files."},"682":{"id":"/integrations/mcp-server-20","page_id":"/integrations/mcp-server","type":"text","url":"/integrations/mcp-server#from-npm-published-packages","content":"The npm package name is hyper-pm-mcp. It lists hyper-pm as a dependency so the CLI is installed next to the server."},"683":{"id":"/integrations/mcp-server-21","page_id":"/integrations/mcp-server","type":"text","url":"/integrations/mcp-server#from-npm-published-packages","content":"Point your MCP host at the hyper-pm-mcp binary from the global install (see which hyper-pm-mcp on Unix), or at the resolved path to dist/main.mjs inside the package directory."},"684":{"id":"/integrations/mcp-server-22","page_id":"/integrations/mcp-server","type":"text","url":"/integrations/mcp-server#register-the-server-in-your-editor","content":"Use node with the absolute path to apps/hyper-pm-mcp/dist/main.mjs (see examples below)."},"685":{"id":"/integrations/mcp-server-23","page_id":"/integrations/mcp-server","type":"text","url":"/integrations/mcp-server#environment","content":"Optional variables are in apps/hyper-pm-mcp/env.example and parsed through @workspace/env."},"686":{"id":"/integrations/mcp-server-24","page_id":"/integrations/mcp-server","type":"text","url":"/integrations/mcp-server#environment","content":"Variable"},"687":{"id":"/integrations/mcp-server-25","page_id":"/integrations/mcp-server","type":"text","url":"/integrations/mcp-server#environment","content":"Purpose"},"688":{"id":"/integrations/mcp-server-26","page_id":"/integrations/mcp-server","type":"text","url":"/integrations/mcp-server#environment","content":"HYPER_PM_CLI_PATH"},"689":{"id":"/integrations/mcp-server-27","page_id":"/integrations/mcp-server","type":"text","url":"/integrations/mcp-server#environment","content":"Absolute path to hyper-pm/dist/main.cjs when require.resolve(\"hyper-pm\") is not sufficient (unusual for published installs)"},"690":{"id":"/integrations/mcp-server-28","page_id":"/integrations/mcp-server","type":"text","url":"/integrations/mcp-server#environment","content":"The child CLI inherits the host process environment: set GITHUB_TOKEN, GITHUB_REPO, HYPER_PM_AI_API_KEY, etc. in the MCP env object (or system environment) so sync and AI flags work the same as in a terminal."},"691":{"id":"/integrations/mcp-server-29","page_id":"/integrations/mcp-server","type":"text","url":"/integrations/mcp-server#tool-hyper_pm_run","content":"Description (for models): runs hyper-pm with JSON output; --format json is always injected by the runner."},"69