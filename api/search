ge_id":"/integrations/mcp-server","type":"text","url":"/integrations/mcp-server#example-tool-inputs","content":"Run validation only:"},"723":{"id":"/integrations/mcp-server-68","page_id":"/integrations/mcp-server","type":"text","url":"/integrations/mcp-server#output","content":"The tool returns text content: a single JSON document (pretty-printed) with exitCode, signal, stderr, stdout, and parsedStdout (parsed CLI JSON when stdout is valid JSON, otherwise null). The Web UI POST /api/run response uses the same parsing for its json field."},"724":{"id":"/integrations/mcp-server-69","page_id":"/integrations/mcp-server","type":"text","url":"/integrations/mcp-server#cursor","content":"Settings → MCP (or your version’s equivalent): add a server entry:"},"725":{"id":"/integrations/mcp-server-70","page_id":"/integrations/mcp-server","type":"text","url":"/integrations/mcp-server#cursor","content":"Replace the args path with your machine’s path (global install: path to main.mjs inside node_modules/hyper-pm-mcp if you prefer). Put secrets in env only where your editor stores them safely."},"726":{"id":"/integrations/mcp-server-71","page_id":"/integrations/mcp-server","type":"text","url":"/integrations/mcp-server#claude-desktop","content":"Add a similar block under mcpServers in Claude’s config file (location varies by OS; see Anthropic’s MCP docs). Use the same command / args / env pattern as Cursor."},"727":{"id":"/integrations/mcp-server-72","page_id":"/integrations/mcp-server","type":"text","url":"/integrations/mcp-server#publishing-maintainers","content":"Publish hyper-pm first, then hyper-pm-mcp, with pnpm publish from each app so workspace: ranges rewrite. Details in apps/hyper-pm-mcp/README.md."},"728":{"id":"/integrations/mcp-server-73","page_id":"/integrations/mcp-server","type":"text","url":"/integrations/mcp-server#publishing-maintainers","content":"type: info"},"729":{"id":"/integrations/mcp-server-74","page_id":"/integrations/mcp-server","type":"text","url":"/integrations/mcp-server#publishing-maintainers","content":"The Web UI uses the same runner schema for POST /api/run (without repo / tempDir in the body). For human-driven CLI usage, see Examples."},"730":{"id":"/integrations/web-ui","page_id":"/integrations/web-ui","type":"page","content":"Web UI (hyper-pm-web)","url":"/integrations/web-ui"},"731":{"id":"/integrations/web-ui-0","page_id":"/integrations/web-ui","type":"text","url":"/integrations/web-ui","content":"Local browser UI and HTTP API around the hyper-pm CLI — install, env, security, and automation."},"732":{"id":"/integrations/web-ui-1","page_id":"/integrations/web-ui","type":"heading","url":"/integrations/web-ui#what-you-get-in-the-browser","content":"What you get in the browser"},"733":{"id":"/integrations/web-ui-2","page_id":"/integrations/web-ui","type":"heading","url":"/integrations/web-ui#security-defaults","content":"Security defaults"},"734":{"id":"/integrations/web-ui-3","page_id":"/integrations/web-ui","type":"heading","url":"/integrations/web-ui#install-and-run","content":"Install and run"},"735":{"id":"/integrations/web-ui-4","page_id":"/integrations/web-ui","type":"heading","url":"/integrations/web-ui#from-npm-published-packages","content":"From npm (published packages)"},"736":{"id":"/integrations/web-ui-5","page_id":"/integrations/web-ui","type":"heading","url":"/integrations/web-ui#from-this-monorepo-development","content":"From this monorepo (development)"},"737":{"id":"/integrations/web-ui-6","page_id":"/integrations/web-ui","type":"heading","url":"/integrations/web-ui#build-the-cli","content":"Build the CLI"},"738":{"id":"/integrations/web-ui-7","page_id":"/integrations/web-ui","type":"heading","url":"/integrations/web-ui#configure-optional","content":"Configure (optional)"},"739":{"id":"/integrations/web-ui-8","page_id":"/integrations/web-ui","type":"heading","url":"/integrations/web-ui#start-the-app","content":"Start the app"},"740":{"id":"/integrations/web-ui-9","page_id":"/integrations/web-ui","type":"heading","url":"/integrations/web-ui#github-sync-and-ai-helpers","content":"GitHub sync and AI helpers"},"741":{"id":"/integrations/web-ui-10","page_id":"/integrations/web-ui","type":"heading","url":"/integrations/web-ui#http-api","content":"HTTP API"},"742":{"id":"/integrations/web-ui-11","page_id":"/integrations/web-ui","type":"heading","url":"/integrations/web-ui#get-apihealth","content":"GET /api/health"},"743":{"id":"/integrations/web-ui-12","page_id":"/integrations/web-ui","type":"heading","url":"/integrations/web-ui#post-apirun","content":"POST /api/run"},"744":{"id":"/integrations/web-ui-13","page_id":"/integrations/web-ui","type":"heading","url":"/integrations/web-ui#publishing-maintainers","content":"Publishing (maintainers)"},"745":{"id":"/integrations/web-ui-14","page_id":"/integrations/web-ui","type":"text","url":"/integrations/web-ui","content":"hyper-pm-web is a small local server that serves a browser UI and an HTTP API. Every action still runs the same bundled hyper-pm binary as the CLI, so behavior, data, and GitHub sync match what you get in the terminal."},"746":{"id":"/integrations/web-ui-15","page_id":"/integrations/web-ui","type":"text","url":"/integrations/web-ui","content":"Use it when you prefer clicking and forms over shell flags, or when you want a stable POST /api/run endpoint for scripts (with the server fixing repo and temp paths)."},"747":{"id":"/integrations/web-ui-16","page_id":"/integrations/web-ui","type":"text","url":"/integrations/web-ui#what-you-get-in-the-browser","content":"The UI is organized in a sidebar, roughly:"},"748":{"id":"/integrations/web-ui-17","page_id":"/integrations/web-ui","type":"text","url":"/integrations/web-ui#what-you-get-in-the-browser","content":"Overview — high-level view of the managed repo."},"749":{"id":"/integrations/web-ui-18","page_id":"/integrations/web-ui","type":"text","url":"/integrations/web-ui#what-you-get-in-the-browser","content":"Epics, Stories, Tickets — list, open, create, edit, and delete work items (same semantics as CLI CRUD)."},"750":{"id":"/integrations/web-ui-19","page_id":"/integrations/web-ui","type":"text","url":"/integrations/web-ui#what-you-get-in-the-browser","content":"Tools — utilities that still go through the CLI."},"751":{"id":"/integrations/web-ui-20","page_id":"/integrations/web-ui","type":"text","url":"/integrations/web-ui#what-you-get-in-the-browser","content":"Advanced CLI — send raw argv (subcommand tokens only; see below) for anything not wrapped as a form."},"752":{"id":"/integrations/web-ui-21","page_id":"/integrations/web-ui","type":"text","url":"/integrations/web-ui#what-you-get-in-the-browser","content":"Ticket flows include comments on tickets, aligned with ticket comment."},"753":{"id":"/integrations/web-ui-22","page_id":"/integrations/web-ui","type":"text","url":"/integrations/web-ui#security-defaults","content":"type: warn"},"754":{"id":"/integrations/web-ui-23","page_id":"/integrations/web-ui","type":"text","url":"/integrations/web-ui#security-defaults","content":"The server defaults to 127.0.0.1 — see HYPER_PM_WEB_HOST. Do not expose it to untrusted networks without TLS and a real authentication layer."},"755":{"id":"/integrations/web-ui-24","page_id":"/integrations/web-ui","type":"text","url":"/integrations/web-ui#security-defaults","content":"--repo, --temp-dir, and --format are always chosen by the server. The browser (or API client) cannot inject them in argv (requests that try are rejected)."},"756":{"id":"/integrations/web-ui-25","page_id":"/integrations/web-ui","type":"text","url":"/integrations/web-ui#security-defaults","content":"Optional HYPER_PM_WEB_TOKEN: when set, POST /api/run requires Authorization: Bearer <token>."},"757":{"id":"/integrations/web-ui-26","page_id":"/integrations/web-ui","type":"text","url":"/integrations/web-ui#from-npm-published-packages","content":"The npm package name is hyper-pm-web. It depends on hyper-pm; installing the web app normally pulls the CLI as a dependency."},"758":{"id":"/integrations/web-ui-27","page_id":"/integrations/web-ui","type":"text","url":"/integrations/web-ui#from-npm-published-packages","content":"From the Git repository you want to manage (so the default repo is your cwd), start the server:"},"759":{"id":"/integrations/web-ui-28","page_id":"/integrations/web-ui","type":"text","url":"/integrations/web-ui#from-npm-published-packages","content":"Or set HYPER_PM_WEB_REPO to an absolute repo path and run from anywhere."},"760":{"id":"/integrations/web-ui-29","page_id":"/integrations/web-ui","type":"text","url":"/integrations/web-ui#configure-optional","content":"Environment variables are documented in apps/hyper-pm-web/env.example and the root packages/env/env.example."},"761":{"id":"/integrations/web-ui-30","page_id":"/integrations/web-ui","type":"text","url":"/integrations/web-ui#configure-optional","content":"Variable"},"762":{"id":"/integrations/web-ui-31","page_id":"/integrations/web-ui","type":"text","url":"/integrations/web-ui#configure-optional","content":"Role"},"763":{"id":"/integrations/web-ui-32","page_id":"/integrations/web-ui","type":"text","url":"/integrations/web-ui#configure-optional","content":"HYPER_PM_WEB_REPO"},"764":{"id":"/integrations/web-ui-33","page_id":"/integrations/web-ui","type":"text","url":"/integrations/web-ui#configure-optional","content":"Git repo root passed as --repo (default: server process cwd, resolved to an absolute path)"},"765":{"id":"/integrations/web-ui-34","page_id":"/integrations/web-ui","type":"text","url":"/integrations/web-ui#configure-optional","content":"HYPER_PM_WEB_TEMP_DIR"},"766":{"id":"/integrations/web-ui-35","page_id":"/integrations/web-ui","type":"text","url":"/integrations/web-ui#configure-optional","content":"Parent for disposable worktrees (--temp-dir). If unset, the server creates a unique directory under the OS temp dir and deletes it on SIGINT / SIGTERM"},"767":{"id":"/integrations/web-ui-36","page_id":"/integrations/web-ui","type":"text","