{
  "name": "hyper-pm",
  "version": "0.1.0",
  "description": "Git-backed work-item CLI with optional GitHub sync",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "hyper-pm": "dist/main.cjs"
  },
  "main": "./dist/index.cjs",
  "exports": {
    ".": "./dist/index.cjs"
  },
  "files": [
    "dist/main.cjs",
    "dist/index.cjs",
    "README.md",
    "env.example"
  ],
  "scripts": {
    "build": "rm -rf dist && esbuild src/main.ts --bundle --platform=node --format=cjs --outfile=dist/main.cjs && esbuild src/npm-publish-entry.ts --bundle --platform=node --format=cjs --outfile=dist/index.cjs --footer:js=\"module.exports={runCli,ExitCode,openDataBranchWorktree,runGit};\"",
    "prepublishOnly": "npm run build",
    "check-types": "tsc --noEmit -p tsconfig.json",
    "lint": "eslint \"src/**/*.ts\"",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {},
  "devDependencies": {
    "@octokit/rest": "^22.0.1",
    "@types/node": "catalog:",
    "@vitest/coverage-v8": "catalog:",
    "@workspace/env": "workspace:*",
    "@workspace/eslint-config": "workspace:*",
    "@workspace/typescript-config": "workspace:*",
    "commander": "^14.0.2",
    "esbuild": "^0.27.0",
    "eslint": "catalog:",
    "typescript": "catalog:",
    "ulid": "^3.0.1",
    "vitest": "catalog:",
    "zod": "catalog:"
  }
}
