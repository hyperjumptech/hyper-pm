# hyper-pm CLI — optional integration (see @workspace/env)

GITHUB_REPO="owner/repo"
# Personal access token for GitHub API; leave empty if you use `gh auth login` instead
GITHUB_TOKEN=""
HYPER_PM_AI_API_KEY=""
# Optional: default audit actor for CLI mutations (overridden by --actor)
HYPER_PM_ACTOR=""
# Optional: git author for data-branch commits when user.name / user.email are unset (see README sync)
HYPER_PM_GIT_USER_NAME=""
HYPER_PM_GIT_USER_EMAIL=""
GIT_AUTHOR_NAME=""
GIT_AUTHOR_EMAIL=""
