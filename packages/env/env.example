# Copy to .env and adjust. Parsed by @workspace/env (Zod).

NODE_ENV="development"
DB_POOLING_URL="postgresql://postgres:root@127.0.0.1:5432/hyperjump-web-framework?schema=public"
DB_URL_NON_POOLING="postgresql://postgres:root@127.0.0.1:5432/hyperjump-web-framework?schema=public"
DB_CERT_BASE_64=""

RESEND_API_KEY=""

# hyper-pm CLI (optional)
GITHUB_OWNER=""
GITHUB_REPO=""
# Personal access token for hyper-pm sync; omit when using `gh auth login`
GITHUB_TOKEN=""
HYPER_PM_AI_API_KEY=""
# Optional: default JSONL audit actor for hyper-pm CLI mutations (overridden by --actor)
HYPER_PM_ACTOR=""
# Optional: absolute path to hyper-pm dist/main.cjs (hyper-pm-mcp and integrations)
HYPER_PM_CLI_PATH=""

# hyper-pm-web (local UI; bind defaults to 127.0.0.1:3847 when host/port unset)
HYPER_PM_WEB_HOST=""
# #number
HYPER_PM_WEB_PORT=""
# Optional — git repo for `--repo` (defaults to process.cwd())
HYPER_PM_WEB_REPO=""
# Optional — parent for disposable worktrees (defaults: server creates a dir under OS temp, removed on shutdown)
HYPER_PM_WEB_TEMP_DIR=""
# Optional bearer token for POST /api/run
HYPER_PM_WEB_TOKEN=""

# Optional: parent for disposable git worktrees (see also hyper-pm --temp-dir)
TMPDIR=""
