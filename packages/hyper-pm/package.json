{
  "name": "@workspace/hyper-pm",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "bin": {
    "hyper-pm": "./dist/main.js"
  },
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "build": "esbuild src/main.ts --bundle --platform=node --format=esm --outfile=dist/main.js --banner:js=\"#!/usr/bin/env node\"",
    "check-types": "tsc --noEmit -p tsconfig.json",
    "lint": "eslint \"src/**/*.ts\"",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@octokit/rest": "^22.0.1",
    "@workspace/env": "workspace:*",
    "commander": "^14.0.2",
    "ulid": "^3.0.1",
    "zod": "catalog:"
  },
  "devDependencies": {
    "esbuild": "^0.27.0",
    "@types/node": "catalog:",
    "@vitest/coverage-v8": "catalog:",
    "eslint": "catalog:",
    "@workspace/eslint-config": "workspace:*",
    "@workspace/typescript-config": "workspace:*",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
